# ==============================================================================
# Mass-ingest configuration
# Copy this file to the appropriate location and rename to '.env':
#   - Stage 2 (observability): cp .env.example 2-observability/.env
# Then fill in the values below before running 'docker compose up'
# ==============================================================================

# ==============================================================================
# ARTIFACT REPOSITORY (Required — choose one option)
# ==============================================================================

# Option A: Nexus / Artifactory / Maven repository (username + password)
PUBLISH_URL=https://nexus.example.com/repository/moderne-ingest/
PUBLISH_USER=your-username
PUBLISH_PASSWORD=your-password

# Option B: Artifactory (API token — alternative to username/password above)
# PUBLISH_URL=https://artifactory.example.com/artifactory/moderne-ingest/
# PUBLISH_TOKEN=your-jfrog-api-token

# Option C: S3 bucket
# PUBLISH_URL=s3://your-bucket/path/to/lsts/
# S3_PROFILE=default                                    # Optional: AWS profile name
# S3_REGION=us-west-2                                   # Optional: For cross-region access
# S3_ENDPOINT=https://minio.example.com                 # Optional: S3-compatible services
# AWS_REGION=us-east-1                                  # Optional: Explicit region for AWS SDK
#
# Note: On EC2 with IAM roles, Docker adds a network hop, so you must set the
# IMDSv2 hop limit to 2. See 1-quickstart/README.md for details.

# ==============================================================================
# SCM CREDENTIALS (Required for private repositories)
# ==============================================================================

# Option A: HTTPS credentials (inline, alternative to volume-mounting .git-credentials)
# GIT_CREDENTIALS=https://username:token@bitbucket.example.com

# Option B: SSH private key (inline, alternative to volume-mounting .ssh/)
# GIT_SSH_CREDENTIALS=-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----

# When using volume mounts instead, uncomment the relevant lines in docker-compose.yml

# ==============================================================================
# MODERNE PLATFORM (Optional — connects LSTs to a Moderne tenant)
# ==============================================================================

# MODERNE_TENANT=https://app.moderne.io
# MODERNE_TOKEN=your-moderne-token

# ==============================================================================
# INGESTION TUNING (Optional)
# ==============================================================================

# Process repos in batches to limit disk usage (default: all at once)
# BATCH_SIZE=50

# Build timeout per batch in seconds (default: 2700 = 45 minutes)
# BUILD_TIMEOUT=2700

# ==============================================================================
# DIAGNOSTICS (Optional)
# ==============================================================================

# Run diagnostics only (no ingestion), container exits after checks
# DIAGNOSE=true

# Run diagnostics before ingestion starts
# DIAGNOSE_ON_START=true

# ==============================================================================
# CLI VERSION (Optional — set as Docker build arg, not runtime env)
# ==============================================================================

# Pin a specific Moderne CLI version (defaults to latest stable)
# MODERNE_CLI_VERSION=3.50.0
