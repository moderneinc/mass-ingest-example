; Configure a private npm registry
; Uncomment and update the following lines as needed

; Set the default registry for all packages
registry=https://your-private-registry.example.com/

; Scoped packages (e.g., @your-org/package-name)
; @your-org:registry=https://your-private-registry.example.com/

; Authentication (use one of the following):
; Token-based auth:
; //your-private-registry.example.com/:_authToken=YOUR_TOKEN
; Basic auth (base64-encoded username:password):
; //your-private-registry.example.com/:_auth=BASE64_ENCODED_CREDENTIALS
